# ZYX AI Environment Configuration
# Copy this file to .env and fill in your values

# ==========================================
# Application Settings
# ==========================================
APP_NAME=ZYX AI
APP_VERSION=1.0.0
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# ==========================================
# Database Configuration
# ==========================================
# PostgreSQL connection string
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/zyx_ai

# Database pool settings
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30

# ==========================================
# Redis Configuration (Optional)
# ==========================================
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=

# Cache settings
CACHE_TTL=300

# ==========================================
# Security Settings
# ==========================================
# Generate a strong secret: openssl rand -hex 32
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Password hashing
BCRYPT_ROUNDS=12

# ==========================================
# Exchange API Configuration
# ==========================================
# Binance (Paper Trading Mode Recommended)
BINANCE_API_KEY=your-binance-api-key
BINANCE_SECRET=your-binance-secret
BINANCE_TESTNET=true

# Bybit (Optional)
BYBIT_API_KEY=your-bybit-api-key
BYBIT_SECRET=your-bybit-secret
BYBIT_TESTNET=true

# ==========================================
# Trading Configuration
# ==========================================
# Leverage settings
MAX_LEVERAGE=10
DEFAULT_LEVERAGE=3

# Risk management
MAX_POSITION_PCT=0.5      # Max 50% of portfolio in one position
RISK_PER_TRADE=0.02       # Risk 2% per trade
MAX_DRAWDOWN_PCT=0.20     # Stop trading at 20% drawdown

# Default stop loss / take profit
DEFAULT_STOP_LOSS_PCT=0.02     # 2% stop loss
DEFAULT_TAKE_PROFIT_PCT=0.04   # 4% take profit (2:1 RR)

# Trading symbols (comma-separated)
TRADING_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT

# ==========================================
# CORS Settings
# ==========================================
# Allowed origins for CORS (comma-separated)
# In production, set this to your frontend domain(s)
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ==========================================
# Rate Limiting
# ==========================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# ==========================================
# Monitoring
# ==========================================
# Prometheus metrics
METRICS_ENABLED=true
METRICS_PORT=9090

# ==========================================
# Feature Flags
# ==========================================
# Enable/disable features
ENABLE_AUTO_TRADING=false      # Set to true for automated trading
ENABLE_WEBSOCKET=true
ENABLE_CACHE=true
ENABLE_PAPER_TRADING=true      # Always true for safety
